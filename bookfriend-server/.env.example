PORT=5050
MONGODB_URI=mongodb://localhost:27017/after_the_last_page
# Optional alias used by some hosts:
# MONGO_URI=mongodb://localhost:27017/after_the_last_page

# LLM provider: mock | ollama | groq | openai
BOOKFRIEND_LLM_PROVIDER=mock

# Groq (when BOOKFRIEND_LLM_PROVIDER=groq)
BOOKFRIEND_GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=your_api_key_here


# OpenAI (when BOOKFRIEND_LLM_PROVIDER=openai)
BOOKFRIEND_OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Ollama (when BOOKFRIEND_LLM_PROVIDER=ollama)
BOOKFRIEND_OLLAMA_URL=http://127.0.0.1:11434/api/chat
BOOKFRIEND_OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# RAG tuning
BOOKFRIEND_MAX_HISTORY=12
BOOKFRIEND_RETRIEVAL_LIMIT=4
BOOKFRIEND_EMBEDDING_DIM=384
