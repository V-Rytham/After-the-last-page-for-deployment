PORT=10000
MONGODB_URI=mongodb://localhost:27017/after_the_last_page
JWT_SECRET=change_me_in_production
CLIENT_URL=http://localhost:5173

# Optional additional allowed frontend origins for CORS/socket.
CLIENT_URL_FALLBACK=
DEV_CLIENT_URL=

# Required for backend -> BookFriend proxy.
BOOKFRIEND_SERVER_URL=http://127.0.0.1:5050
BOOKFRIEND_ALLOW_LOCAL_FALLBACK=false

# Quiz engine integration.
QUIZ_QUESTION_ENGINE_URL=https://deterministic-question-engine-3sd2.onrender.com
QUIZ_QUESTION_ENGINE_FALLBACK_URLS=
QUIZ_PASS_THRESHOLD_PERCENT=60
ALLOW_MEET_FALLBACK_ON_QUIZ_ERROR=true
MEET_FALLBACK_TTL_HOURS=24

# Recommendations + search enrichment.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=12000
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GOOGLE_BOOKS_API_KEY=

# Google OAuth (set only if enabling Google login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Optional runtime/deployment helpers.
PUBLIC_SERVER_URL=
RENDER_EXTERNAL_HOSTNAME=
BOOK_BACKEND_TIMEOUT_MS=70000
BOOK_SEARCH_CACHE_TTL_MS=300000
BOOK_METADATA_CACHE_TTL_MS=300000
BOOK_SEARCH_THROTTLE_MS=450
BOOK_READER_PROCESSING_BUDGET_MS=40000

# Optional email provider (currently non-blocking if absent).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
