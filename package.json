{
  "name": "after-the-last-page",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node backend/index.js",
    "dev:full": "concurrently -n server,web -c blue,green \"npm run server\" \"npm run dev -- --host\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "bookfriend": "npm --prefix bookfriend-server start",
    "dev:all": "concurrently -n server,bookfriend,web -c blue,magenta,green \"npm run server\" \"npm run bookfriend\" \"npm run dev -- --host\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "vite": "^7.3.1"
  }
}
